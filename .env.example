# Copie este arquivo para .env no servidor e ajuste os valores.

APP_DOMAIN=passagemdeplantao.eletrostarsoft.com.br
NEXT_PUBLIC_API_URL=https://passagemdeplantao.eletrostarsoft.com.br/api
CORS_ORIGIN=https://passagemdeplantao.eletrostarsoft.com.br,http://localhost:3000

# Use a connection string valida do Supabase/PostgreSQL.
DATABASE_URL=postgresql://usuario:senha@host:6543/postgres
DIRECT_URL=postgresql://usuario:senha@host:5432/postgres

# Em producao, deixe 127.0.0.1 quando houver Nginx/Caddy/Traefik na VPS.
# Use 0.0.0.0 apenas se for expor as portas diretamente na internet.
BIND_IP=127.0.0.1
FRONTEND_PORT=3000
BACKEND_PORT=4000

# Para Traefik em Docker, crie/use a mesma rede externa do Traefik.
DOCKER_NETWORK=cti-app-network
DOCKER_NETWORK_EXTERNAL=false

# Ative apenas se o servidor ja usa Traefik.
TRAEFIK_ENABLE=false
TRAEFIK_ENTRYPOINT=websecure
TRAEFIK_CERTRESOLVER=letsencrypt
